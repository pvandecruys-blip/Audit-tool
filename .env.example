# PwC GenAI gateway config for the AI Copilot chat.
# Copy to .env.local for local dev (it is gitignored). On Vercel, set these in
# Project Settings → Environment Variables. Without them the chat falls back to
# built-in mock answers.

# Secret key for the GenAI shared service. NEVER commit the real value.
GENAI_API_KEY=

# Full chat-completions endpoint of the gateway (must be reachable from Vercel,
# so use the public .pwc.com host, not the pwcinternal.com one).
# Example (OpenAI-compatible): https://genai-sharedservice-emea.pwc.com/genai/v1/chat/completions
GENAI_BASE_URL=

# Model id to use, e.g. gpt-4o | claude-3-5-sonnet | gemini-1.5-pro
GENAI_MODEL=gpt-4o
