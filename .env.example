# PwC GenAI gateway config for the AI Copilot chat.
# Copy to .env.local for local dev (it is gitignored). On Vercel, set these in
# Project Settings → Environment Variables. Without them the chat falls back to
# built-in mock answers.

# Secret key for the GenAI shared service. NEVER commit the real value.
GENAI_API_KEY=

# Full chat-completions endpoint of the gateway (must be reachable from Vercel,
# so use the public .pwc.com host, not the pwcinternal.com one).
# Example (OpenAI-compatible): https://genai-sharedservice-emea.pwc.com/genai/v1/chat/completions
GENAI_BASE_URL=

# Model id to use. PwC GenAI uses provider-prefixed ids, e.g.
#   vertex_ai.anthropic.claude-opus-4-6 | gpt-4o | gemini-1.5-pro
GENAI_MODEL=vertex_ai.anthropic.claude-opus-4-6

# (Optional) How the key is sent. Defaults work for OpenAI/Bearer gateways.
# If the gateway returns 403, try a different header here:
#   - Bearer (default):    leave both unset
#   - api-key header:      GENAI_AUTH_HEADER=api-key      GENAI_AUTH_SCHEME=
#   - Azure APIM:          GENAI_AUTH_HEADER=Ocp-Apim-Subscription-Key   GENAI_AUTH_SCHEME=
# GENAI_AUTH_HEADER=Authorization
# GENAI_AUTH_SCHEME=Bearer
